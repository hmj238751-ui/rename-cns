{
  "manifest_version": 3,
  "name": "论文文献智能改名",
  "version": "1.0.2",
  "description": "自动将论文下载文件命名为年份-期刊-标题。 Automatically rename downloaded papers as year-journal-title.",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://api.crossref.org/*",
    "https://eutils.ncbi.nlm.nih.gov/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "论文文献智能改名",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
